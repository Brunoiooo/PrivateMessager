# PostgreSQL
POSTGRES_DB=messager
POSTGRES_USER=messager
POSTGRES_PASSWORD=change-me

# API binding
API_BIND_IP=0.0.0.0
API_BIND_PORT=5000

# JWT — generate with: openssl rand -base64 64
JWT_SIGNING_KEY=replace-with-strong-random-base64-value

# Message TTL — days before undelivered messages are deleted from the server (default: 30)
MESSAGE_TTL_DAYS=30

# Android builder — URL the APK will call at runtime
# Emulator:         http://10.0.2.2:5000
# Physical (ADB):   http://127.0.0.1:5000
# LAN / server:     https://<IP>:5000
MESSAGER_API_BASE_URL=http://10.0.2.2:5000

# SSL — place certs in ./ssl/ directory before starting
# Server cert + key used by nginx
# Mobile CA cert bundled into the APK (must be the CA that signed the server cert)
# Leave SSL_CA_CERT_FILE empty to build without SSL (HTTP only)
NGINX_EXTERNAL_PORT=5000
SSL_CA_CERT_FILE=ca.pem
